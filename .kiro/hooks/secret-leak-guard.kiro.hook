{
  "enabled": true,
  "name": "敏感信息检查",
  "description": "修改 application.yml 时检查是否包含硬编码的 API Key 或密码",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "src/main/resources/application*.yml"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "用户修改了 application.yml 配置文件。请检查文件中是否存在硬编码的敏感信息，包括：api-key、password、secret 等字段是否包含真实值（非占位符）。如果发现，提醒用户改用环境变量。"
  }
}